{
  "name": "@webcv6/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./styles": "./src/styles/index.css"
  },
  "scripts": {
    "build": "vue-tsc -p tsconfig.json && vite build",
    "dev": "vite",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.vue",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@webcv6/core": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0"
  }
}
