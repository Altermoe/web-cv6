    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.23.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "playwright": "1.52.0",
    "tsup": "8.5.0",
    "tsx": "4.20.0",
    "typescript": "catalog:",
    "vitest": "3.2.3"
  }
}
