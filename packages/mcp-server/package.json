{
  "name": "@webcv6/mcp-server",
  "version": "0.0.0",
  "description": "WebGPU 自动评估 MCP Server — Playwright + CDP 截图反馈工具",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "webgpu-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
