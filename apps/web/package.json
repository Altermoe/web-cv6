{
  "name": "@webcv6/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.web.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck:web": "vue-tsc -p tsconfig.web.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck": "npm run typecheck:web && npm run typecheck:node"
  },
  "dependencies": {
    "@webcv6/core": "workspace:*",
    "@webcv6/gpu3d": "workspace:*",
    "@webcv6/server": "workspace:*",
    "@webcv6/ui": "workspace:*",
    "pinia": "3.0.4",
    "reka-ui": "2.9.10",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "typescript": "catalog:",
    "unocss": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": ">=26"
  }
}
