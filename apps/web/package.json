{
  "name": "@webcv6/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@webcv6/core": "workspace:*",
    "@webcv6/gpu3d": "workspace:*",
    "@webcv6/server": "workspace:*",
    "@webcv6/ui": "workspace:*",
    "pinia": "3.0.4",
    "reka-ui": "2.9.10",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "typescript": "6.0.3",
    "unocss": "66.7.2",
    "vite": "8.0.16",
    "vue-tsc": "3.3.5"
  },
  "engines": {
    "node": ">=26"
  }
}
